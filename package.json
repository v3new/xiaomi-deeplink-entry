{
  "name": "xiaomi-deeplink-entry",
  "version": "1.0.0",
  "description": "Deeplink launcher for Xiaomi HyperOS cast to a car display",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "icons:download": "node scripts/download-app-icons.mjs --refresh",
    "preview": "vite preview",
    "start": "bun server/index.mjs",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "tunnel": "ngrok http 8080"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ],
  "dependencies": {
    "hono": "^4.12.25"
  }
}
