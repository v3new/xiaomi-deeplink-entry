{
  "name": "xiaomi-deeplink-entry",
  "version": "1.0.0",
  "description": "Static deeplink launcher for Xiaomi HyperOS cast to a car display",
  "private": true,
  "scripts": {
    "serve": "http-server . -p 8080 -c-1 --silent",
    "tunnel": "ngrok http 8080",
    "dev": "concurrently --kill-others --names \"web,ngrok\" --prefix-colors \"cyan,magenta\" \"npm:serve\" \"npm:tunnel\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "http-server": "^14.1.1"
  }
}
